# Configurações do Supabase para VinculoTEA
# Obtenha estes valores em Project Settings > API no seu painel do Supabase

# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave Anônima Pública (segura para o frontend)
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# NUNCA coloque a service_role key aqui se estiver usando no frontend!